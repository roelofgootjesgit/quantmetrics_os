# Copy to .env (gitignored). Canonical place for VPS secrets when using this orchestrator.
# See quantbuildv1/docs/CREDENTIALS_AND_ENVIRONMENT.md for variable names.

QUANTBUILD_ROOT=/root/dev/quant/quantbuildv1
QUANTBRIDGE_ROOT=/root/dev/quant/quantbridgev1

# Interpreter for subprocesses (optional; defaults to QUANTBUILD_ROOT/.venv/bin/python)
# PYTHON=/root/dev/quant/quantbuildv1/.venv/bin/python
#
# cTrader demo (IC): quantmetrics.py build --real -c configs/demo_strict_ctrader.yaml

# QuantBuild / news / brokers / Telegram — same names as in CREDENTIALS_AND_ENVIRONMENT.md
# OANDA_ACCOUNT_ID=
# OANDA_TOKEN=
# CTRADER_ACCOUNT_ID=
# CTRADER_ACCESS_TOKEN=
# QUANTBRIDGE_SRC_PATH=/root/dev/quant/quantbridgev1/src
# FINNHUB_API_KEY=
# TELEGRAM_BOT_TOKEN=
# ...
